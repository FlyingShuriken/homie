# ZhipuAI / Z.AI credentials
GLM_API_KEY=your_zhipuai_api_key_here
GLM_MODEL=glm-4-flash          # Set to the exact model ID provided by Z.AI (e.g. glm-5, glm-5-air)

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/homie

# Pipeline behaviour
DEMO_SEED=false                 # true = use fixture data instead of live scraping (demo fallback)
MAX_LISTINGS_PER_SOURCE=25      # max results fetched per scraper
GLM_ORCHESTRATOR_MAX_ITERATIONS=30  # max iterations for the top-level orchestrator loop
GLM_MAX_ITERATIONS=10               # max ReAct loop iterations per stage sub-agent
GLM_RETRY_DELAY_SECONDS=5       # seconds to wait before retrying a failed GLM call

# Scraper anti-bot settings
SCRAPER_REQUEST_DELAY_MIN=1     # min seconds between requests
SCRAPER_REQUEST_DELAY_MAX=3     # max seconds between requests

# Logging
LOG_LEVEL=INFO
